# Space Intelligence Dashboard - Environment Variables
# Copy this file to .env and fill in your actual values

# News API (optional - app uses Spaceflight News API which is free and keyless)
VITE_NEWS_API_KEY=your_newsapi_key_here

# HuggingFace API token (optional - for future AI integration)
VITE_AI_TOKEN=your_huggingface_token_here
